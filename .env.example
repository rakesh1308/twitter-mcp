# Required (OAuth 1.0a — read + write)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Optional
ACCOUNT_NAME=Twitter Account
HOST=0.0.0.0
# PORT — leave unset on Zeabur (it injects this)

# Optional (OAuth 2.0 — enables follow / unfollow / get_following / get_followers)
# TWITTER_OAUTH2_CLIENT_ID=
# TWITTER_OAUTH2_CLIENT_SECRET=
# TWITTER_OAUTH2_ACCESS_TOKEN=
# TWITTER_OAUTH2_REFRESH_TOKEN=
# TWITTER_OAUTH2_EXPIRES_AT=2026-07-17T14:00:00Z
# TWITTER_OAUTH2_SCOPE=tweet.read users.read follows.read follows.write offline.access
# TWITTER_OAUTH2_TOKEN_FILE=/data/oauth2.json
# OAUTH2_REFRESH_SKEW_SECONDS=60