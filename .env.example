# Twitter MCP Server - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# ACCOUNT 1 (Required - OAuth 1.0a)
# ============================================
# Friendly name for this account (used in tool parameters)
ACCOUNT1_NAME=Account1

# Twitter API Key (get from Twitter Developer Portal > Keys and tokens)
# This is the API Key (not the Bearer Token)
ACCOUNT1_API_KEY=your_api_key_here

# Twitter API Secret Key
ACCOUNT1_API_SECRET=your_api_secret_here

# Twitter Access Token (user-specific, from Keys and tokens)
ACCOUNT1_ACCESS_TOKEN=your_access_token_here

# Twitter Access Token Secret
ACCOUNT1_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ============================================
# ACCOUNT 2 (Optional - remove if not needed)
# ============================================
ACCOUNT2_NAME=Account2
ACCOUNT2_API_KEY=your_second_api_key_here
ACCOUNT2_API_SECRET=your_second_api_secret_here
ACCOUNT2_ACCESS_TOKEN=your_second_access_token_here
ACCOUNT2_ACCESS_TOKEN_SECRET=your_second_access_token_secret_here

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port to listen on (Zeabur provides this via PORT env var)
PORT=3000

# Host to bind to
HOST=0.0.0.0