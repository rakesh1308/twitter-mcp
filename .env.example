# Twitter MCP Server - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# ACCOUNT 1 (GrowthDigest)
# ============================================
ACCOUNT1_NAME=GrowthDigest
ACCOUNT1_API_KEY=your_api_key_here
ACCOUNT1_API_SECRET=your_api_secret_here
ACCOUNT1_ACCESS_TOKEN=your_access_token_here
ACCOUNT1_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ============================================
# ACCOUNT 2 (noetic_rakesh)
# ============================================
ACCOUNT2_NAME=noetic_rakesh
ACCOUNT2_API_KEY=your_api_key_here
ACCOUNT2_API_SECRET=your_api_secret_here
ACCOUNT2_ACCESS_TOKEN=your_access_token_here
ACCOUNT2_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
HOST=0.0.0.0